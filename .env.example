# ─── Server Configuration ───────────────────────────────
# Port the server listens on (cloud hosts set this automatically)
PORT=3001

# Environment: 'development' or 'production'
NODE_ENV=development

# Maximum concurrent WebSocket connections
MAX_CONNECTIONS=100

# Allowed origins for WebSocket connections (comma-separated)
# Use '*' to allow all origins, or specify exact origins:
# ALLOWED_ORIGINS=https://my-app.railway.app,https://my-domain.com
ALLOWED_ORIGINS=*

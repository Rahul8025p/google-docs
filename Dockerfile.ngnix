# ------- Dockerfile.nginx -------
# Base image – tiny Alpine with NGINX pre‑installed
FROM nginx:alpine

# Copy your custom NGINX configuration into the container
# (the file lives in the repo at nginx/nginx.conf)
COPY nginx/nginx.conf /etc/nginx/nginx.conf

# Expose the public HTTP port
EXPOSE 80

# IMPORTANT: run NGINX in the foreground.
# If you forget this, the container will exit immediately.
CMD ["nginx", "-g", "daemon off;"]
# --------------------------------

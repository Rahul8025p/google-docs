{
  "name": "collab-editor",
  "version": "1.0.0",
  "description": "Production-level Real-time Collaborative Editor",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "docker:build": "docker build -t collab-editor .",
    "docker:run": "docker run -p 3001:3001 --env-file .env collab-editor",
    "docker:compose": "docker-compose up --build",
    "health": "curl -s http://localhost:3001/health | node -e \"process.stdin.on('data',d=>console.log(JSON.parse(d)))\""
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.21.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}
